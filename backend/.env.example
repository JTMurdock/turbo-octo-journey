# Backend — required environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# IBM watsonx.ai API key (from IBM Cloud → Manage → Access → API Keys)
WATSONX_API_KEY=your_api_key_here

# watsonx.ai project ID (found in your watsonx project settings → Manage tab)
WATSONX_PROJECT_ID=your_project_id_here

# Regional service endpoint — must match the region your project lives in
# Common values:
#   us-south  → https://us-south.ml.cloud.ibm.com
#   eu-de     → https://eu-de.ml.cloud.ibm.com
#   eu-gb     → https://eu-gb.ml.cloud.ibm.com
#   jp-tok    → https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model ID — leave as default unless you want to swap models
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct
