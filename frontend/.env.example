# Frontend — optional environment variables
# Copy this file to .env to override defaults.

# Backend base URL — defaults to http://localhost:8000 if not set
VITE_API_URL=http://localhost:8000

# Unsplash Access Key — get one free at https://unsplash.com/developers
# Create an app, copy the "Access Key" (not the Secret Key)
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
